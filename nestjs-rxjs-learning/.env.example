# ============================================
# TEMPLATE CẤU HÌNH - Copy thành .env rồi điền giá trị
# ============================================

APP_PORT=3000
APP_ENV=development
API_PREFIX=api/v1

# Database (SQLite cho dev, MySQL cho prod)
DB_TYPE=better-sqlite3
DB_DATABASE=database.sqlite
DB_SYNCHRONIZE=true
# DB_HOST=localhost
# DB_PORT=3306
# DB_USERNAME=root
# DB_PASSWORD=
# DB_DATABASE=nestjs_learning

# JWT
JWT_SECRET=your-secret-key
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRATION=7d

# Throttle
THROTTLE_TTL=60000
THROTTLE_LIMIT=100
